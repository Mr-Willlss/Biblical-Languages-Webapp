rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }
    function isBootstrapAdmin() {
      return signedIn() && request.auth.token.email == "samiduvimo@gmail.com";
    }
    function isAdmin() {
      return signedIn()
        && (isBootstrapAdmin()
          || request.auth.token.admin == true
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) && request.resource.data.get("role", "student") == "student";
      allow update: if (isOwner(uid)
          && request.resource.data.get("role", "student") == resource.data.get("role", "student")
          && request.resource.data.get("isAdmin", false) == resource.data.get("isAdmin", false))
        || isAdmin();
      allow delete: if false;

      // Greek and Hebrew progress are separate — no cross-language collision
      match /progress_greek/{lessonId} {
        allow read, write: if isOwner(uid);
      }
      match /progress_hebrew/{lessonId} {
        allow read, write: if isOwner(uid);
      }
      // Legacy progress path for backwards compatibility
      match /progress/{lessonId} {
        allow read, write: if isOwner(uid);
      }
      match /lessonCompletions/{docId} {
        allow read, write: if isOwner(uid);
      }
      match /private/{docId} {
        allow read, write: if isOwner(uid);
      }
      match /activity/{activityId} {
        allow read, write: if isOwner(uid);
      }
      match /vocab_favorites/{wordId} {
        allow read, write: if isOwner(uid);
      }
      match /notifications/{notificationId} {
        allow read: if isOwner(uid);
        allow create: if signedIn()
          && request.resource.data.fromUid == request.auth.uid
          && request.resource.data.read == false;
        allow update, delete: if isOwner(uid);
      }
    }

    // Leaderboard: public reads for signed-in users; owner can write
    match /leaderboard/{uid} {
      allow read: if signedIn();
      allow create, update: if isOwner(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.xp_total is number
        && request.resource.data.xp_greek is number
        && request.resource.data.xp_hebrew is number
        && request.resource.data.level is number;
      allow delete: if false;
    }

    // Public activity feed
    match /activities/{activityId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.actorUid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Admin-managed study groups and announcements
    match /study_groups/{groupId} {
      allow read, write: if isAdmin();
    }
    match /announcements/{announcementId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // Admin audit records
    match /admin_audit/{auditId} {
      allow read, write: if isAdmin();
    }

    // Study rooms
    match /studyRooms/{roomId} {
      allow create: if signedIn() && request.resource.data.host == request.auth.uid;
      allow read, update: if signedIn() && request.auth.uid in resource.data.members;
      allow delete: if signedIn() && resource.data.host == request.auth.uid;
    }
    // New project uses study_rooms (snake_case) — support both
    match /study_rooms/{roomId} {
      allow create: if signedIn()
        && request.resource.data.hostUid == request.auth.uid
        && request.auth.uid in request.resource.data.memberUids;
      allow read, update: if signedIn() && request.auth.uid in resource.data.memberUids;
      allow delete: if signedIn() && resource.data.hostUid == request.auth.uid;
    }

    // Practice highscores
    match /practiceScores/{scoreId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    // Lesson content
    match /lessons/{lessonId} {
      allow read: if signedIn();
    }

    // Friendships and friend requests
    match /friendships/{docId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid in request.resource.data.members;
      allow update, delete: if signedIn() && request.auth.uid in resource.data.members;
    }
    match /friendRequests/{docId} {
      allow read: if signedIn()
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toUid == request.auth.uid);
      allow create: if signedIn() && request.resource.data.fromUid == request.auth.uid;
      allow delete: if signedIn()
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toUid == request.auth.uid);
    }

    // Username reservation
    match /usernames/{username} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.resource.data.uid == request.auth.uid;
    }

    // Gifts
    match /gifts/{giftId} {
      allow read: if signedIn()
        && (resource.data.senderUid == request.auth.uid
            || resource.data.recipientUid == request.auth.uid);
      allow create: if signedIn() && request.resource.data.senderUid == request.auth.uid;
    }

    // Lock down everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
